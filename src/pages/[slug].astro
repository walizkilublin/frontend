---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import fetchApi from "../lib/strapi";

// Funkcja getStaticPaths mówi Astro, jakie podstrony ma wygenerować podczas budowania (hybrydowo)
export async function getStaticPaths() {
  let legalPages = { data: [] };

  try {
    legalPages = await fetchApi<any>({
      endpoint: "legal-pages", // Upewnij się, że tak nazywa się Twój endpoint w Strapi
      query: { populate: "*" },
    });
  } catch (error) {
    console.error("Błąd pobierania stron prawnych:", error);
  }

  return legalPages.data.map((page: any) => ({
    params: { slug: page.slug },
    props: { page },
  }));
}

const { page } = Astro.props;

// Pobieranie ustawień globalnych dla nagłówka i stopki ze Strapi (podobnie jak na stronie głównej index.astro)
let globalSettings = null;
try {
  globalSettings = await fetchApi<any>({ endpoint: "global-setting" });
} catch (e) {
  console.error("Błąd pobierania ustawień globalnych w podstronie:", e);
}

const data = globalSettings?.data || {
  phone_main: "+48 500 600 700",
  email_contact: "kontakt@walizki-lublin.pl",
  warehouse_address: "ul. Przykładowa 1\n20-000 Lublin",
  hero_headline_line1: "HURTOWNIA BAGAŻU",
  hero_headline_line2: "OD 2003",
  hero_subheadline: "Zaopatrujemy liderów rynku detalicznego. Bezpieczeństwo. Terminowość. Marża.",
  shipping_prepaid_pln: 18,
  shipping_cod_pln: 26
};

// Skoro mamy CKEditor 5, to zmienna page.content zawiera gotowy HTML!
const contentHtml = page.content || "<p>Brak treści dokumentu.</p>";
---

<Layout
  title={`${page.title} | Hurtownia Bagażu B2B`}
  description={`Dokument techniczny: ${page.title}`}
>
  <Header phone={data.phone_main} />
  <main
    class="pt-[140px] pb-24 min-h-screen bg-ghost-white relative z-10 selection:bg-signal-orange selection:text-white"
  >
    <div class="max-w-[1200px] mx-auto px-4 md:px-8">
      <div class="mb-20 border-b-2 border-vantablack pb-12 animate-fade-in-up">
        <div class="flex items-center gap-4 mb-6">
          <span class="w-3 h-3 bg-signal-orange animate-pulse"></span>
          <span
            class="text-[10px] md:text-xs font-mono font-bold tracking-widest text-cool-grey uppercase"
            >Dokumentacja Prawna</span
          >
        </div>
        <h1
          class="text-5xl md:text-7xl lg:text-8xl font-black uppercase tracking-tighter text-vantablack leading-none"
        >
          {page.title}
        </h1>
      </div>

      <!-- Globalna warstwa klasowa .strapi-content (z global.css) dbająca o spójność "brudnego" HTML z CKEditora -->
      <article class="strapi-content">
        <Fragment set:html={contentHtml} />
      </article>

      <div
        class="mt-24 pt-12 border-t-4 border-vantablack flex justify-between items-center"
      >
        <a
          href="/"
          class="inline-flex items-center gap-3 bg-white border border-border-tech text-vantablack font-bold uppercase tracking-widest text-[10px] px-6 md:px-8 py-4 hover:border-signal-orange hover:text-signal-orange transition-colors duration-300"
        >
          <svg
            class="w-4 h-4 rotate-180"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
            ><path
              stroke-linecap="square"
              stroke-linejoin="miter"
              stroke-width="2"
              d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg
          >
          <span class="hidden md:block">Powrót do strony głównej</span>
          <span class="block md:hidden">Wróć</span>
        </a>
        <div
          class="text-[10px] font-mono text-cool-grey uppercase tracking-widest"
        >
          DOC_VER: {new Date().getFullYear()}
        </div>
      </div>
    </div>
  </main>
  <Footer settings={data} />
</Layout>
