---
export interface Props {
  line1?: string;
  line2?: string;
  subheadline?: string;
}

const { 
  line1 = "HURTOWNIA BAGAŻU", 
  line2 = "OD 2003", 
  subheadline = "Zaopatrujemy liderów rynku detalicznego. Bezpieczeństwo. Terminowość. Marża." 
} = Astro.props;
---

<section id="wl-hero" class="relative w-full h-screen min-h-[550px] overflow-hidden bg-ghost-white cursor-crosshair">
  
  <div class="absolute inset-0 pointer-events-none opacity-[0.03] z-0">
    <div class="absolute inset-0 bg-[linear-gradient(rgba(17,24,39,1)_1px,transparent_1px),linear-gradient(90deg,rgba(17,24,39,1)_1px,transparent_1px)] bg-[size:40px_40px]"></div>
  </div>

  <div class="absolute top-[120px] lg:top-[140px] inset-x-0 flex justify-center z-10 pointer-events-none animate-fade-in-up" style="--anim-delay: 0s;">
   <div style="transform: translate(calc(var(--mx, 0) * -5px), calc(var(--my, 0) * -5px));">
      <h1 class="font-black uppercase tracking-tighter text-vantablack leading-[0.85] opacity-90 text-center px-4 flex flex-col md:flex-row md:gap-4 whitespace-nowrap"
          style="font-size: clamp(3rem, 9vw, 11rem);">
        {line1.split(' ').map((word) => (
          <span>{word}</span>
        ))}
      </h1>
    </div>
  </div>

  <div class="absolute inset-0 z-20 flex items-center justify-center pointer-events-none mt-10" style="perspective: 1200px;">
    <div class="relative flex flex-col items-center justify-center animate-fade-in-up will-change-transform"
         style="--anim-delay: 0.2s; transform-style: preserve-3d; font-size: clamp(3px, min(calc((100vh - 450px) / 60), calc(100vw / 50)), 10px); transform: translate3d(calc(var(--mx, 0) * 10px), calc(var(--my, 0) * 10px), 0px) rotateX(calc(var(--my, 0) * -3deg)) rotateY(calc(var(--mx, 0) * 3deg));">
      
      <div class="absolute -bottom-[6.4em] w-[30em] h-[4em] bg-black/30 blur-2xl rounded-full backface-hidden" style="transform: translateZ(-50px);"></div>

      <div class="absolute -top-[6.4em] w-[12.8em] h-[8em] flex justify-between backface-hidden" style="transform: translateZ(-20px);">
        <div class="w-[1.2em] h-full bg-gradient-to-r from-gray-400 via-gray-200 to-gray-500"></div>
        <div class="w-[1.2em] h-full bg-gradient-to-r from-gray-400 via-gray-200 to-gray-500"></div>
        <div class="absolute top-0 left-0 w-full h-[2.4em] bg-vantablack rounded-t-[0.8em] shadow-md border-t border-gray-600"></div>
      </div>

      <div class="relative w-[32em] h-[50em] bg-[#D1D5DB] rounded-[3.2em] border-[3px] border-vantablack overflow-hidden shadow-[2em_2em_6em_rgba(0,0,0,0.2)] backface-hidden"
           style="transform-style: preserve-3d;">
        
        <div class="absolute inset-x-[2.4em] inset-y-[1.6em] flex justify-between z-10 pointer-events-none">
          {Array.from({ length: 7 }).map(() => (
            <div class="w-[2.4em] h-full bg-black/5 rounded-full border-l border-white/50 border-r border-black/10"></div>
          ))}
        </div>

        <div class="absolute top-[3.2em] right-[3.2em] bg-vantablack text-signal-orange text-[0.9em] font-mono p-[0.8em] z-20 shadow-md border border-signal-orange/30 backface-hidden">
          ID: W-204<br/>CLR
        </div>

        <div class="absolute inset-0 z-40 pointer-events-none opacity-0 animate-glare-sweep mix-blend-overlay">
          <div class="w-[200%] h-full bg-gradient-to-r from-transparent via-white to-transparent transform -skew-x-12 blur-sm"></div>
        </div>

      </div>

      <div class="absolute -top-[0.4em] -left-[0.4em] w-[4em] h-[4em] bg-vantablack rounded-tl-[3.2em] rounded-br-[1.2em] z-30 backface-hidden"></div>
      <div class="absolute -top-[0.4em] -right-[0.4em] w-[4em] h-[4em] bg-vantablack rounded-tr-[3.2em] rounded-bl-[1.2em] z-30 backface-hidden"></div>
      <div class="absolute -bottom-[0.4em] -left-[0.4em] w-[4em] h-[4em] bg-vantablack rounded-bl-[3.2em] rounded-tr-[1.2em] z-30 backface-hidden"></div>
      <div class="absolute -bottom-[0.4em] -right-[0.4em] w-[4em] h-[4em] bg-vantablack rounded-br-[3.2em] rounded-tl-[1.2em] z-30 backface-hidden"></div>

      <div class="absolute -bottom-[3.2em] left-[3.2em] w-[2.4em] h-[4em] flex flex-col items-center z-10 backface-hidden" style="transform: translateZ(-10px);">
        <div class="w-[1.2em] h-[1.6em] bg-gray-400"></div>
        <div class="w-[2.4em] h-[2.4em] bg-vantablack rounded-full"></div>
      </div>
      <div class="absolute -bottom-[3.2em] right-[3.2em] w-[2.4em] h-[4em] flex flex-col items-center z-10 backface-hidden" style="transform: translateZ(-10px);">
        <div class="w-[1.2em] h-[1.6em] bg-gray-400"></div>
        <div class="w-[2.4em] h-[2.4em] bg-vantablack rounded-full"></div>
      </div>

    </div>
  </div>

  <div class="absolute bottom-[120px] lg:bottom-[140px] inset-x-0 flex flex-col items-center z-30 pointer-events-none animate-fade-in-up" style="--anim-delay: 0.3s;">
    <div style="transform: translate(calc(var(--mx, 0) * -5px), calc(var(--my, 0) * -5px));">
      <h2 class="font-black uppercase tracking-tighter leading-none text-outline px-8"
          style="font-size: clamp(3.5rem, 10vw, 11rem);">
        {line2}
      </h2>
    </div>
  </div>

  <div class="absolute bottom-6 md:bottom-10 inset-x-0 z-40 px-4 flex justify-center pointer-events-none animate-fade-in-up" style="--anim-delay: 0.5s;">
    <p class="text-xs md:text-sm lg:text-base font-medium text-cool-grey max-w-xl text-center tracking-wide bg-ghost-white/90 py-3 px-8 backdrop-blur-md rounded-full border border-vantablack/10 shadow-sm pointer-events-auto">
      {subheadline}
    </p>
  </div>

</section>

<script is:inline>
  document.addEventListener('astro:page-load', () => {
    const hero = document.getElementById('wl-hero');
    if (!hero) return;

    let targetX = 0, targetY = 0;
    let currentX = 0, currentY = 0;
    
    const damping = 0.08; 

    function onMouseMove(e) {
      targetX = (e.clientX / window.innerWidth - 0.5) * 2;
      targetY = (e.clientY / window.innerHeight - 0.5) * 2;
    }

    function animate() {
      currentX += (targetX - currentX) * damping;
      currentY += (targetY - currentY) * damping;

      hero.style.setProperty('--mx', currentX.toFixed(4));
      hero.style.setProperty('--my', currentY.toFixed(4));

      requestAnimationFrame(animate);
    }

    window.addEventListener('mousemove', onMouseMove);
    animate();
  });
</script>

<style>
  .text-outline {
    color: transparent;
    -webkit-text-stroke: 3px #111827; 
  }
  @media (max-width: 768px) {
    .text-outline { -webkit-text-stroke: 2px #111827; }
  }
  .backface-hidden {
    -webkit-backface-visibility: hidden;
    backface-visibility: hidden;
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(2rem); }
    to { opacity: 1; transform: translateY(0); }
  }

  .animate-fade-in-up {
    opacity: 0;
    animation: fadeInUp 1s ease-out forwards;
    animation-delay: var(--anim-delay, 0s);
  }

  @keyframes glareSweep {
    0% { transform: translateX(-150%); opacity: 0; }
    20% { opacity: 0.8; }
    80% { transform: translateX(50%); opacity: 0; }
    100% { transform: translateX(50%); opacity: 0; }
  }
  
  .animate-glare-sweep {
    animation: glareSweep 1.5s cubic-bezier(0.25, 0.1, 0.25, 1) forwards;
    animation-delay: 1.5s; 
  }
</style>